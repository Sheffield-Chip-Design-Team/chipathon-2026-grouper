CAPI=2:

name: sharc:comms_ip:ahb_uart_directed:0.0.1
description: Simple directed cocotb testbench for ahb_uart (Verilator)

filesets:
  rtl:
    depend:
      - sharc:comms_ip:ahb_uart:0.0.1

targets:
  default:
    flow: sim
    flow_options:
      tool: verilator
      cocotb_module: hw.tb.uart.test_uart
      verilator_options:
        - -Wno-TIMESCALEMOD
        - --sv
        - --trace
        - --trace-fst
      run_options:
        - --trace
    filesets: [rtl]
    toplevel: ahb_uart
